class Program
{
    static void Main(){

        Console.WriteLine("Zadej vysku v m:");
            double vyska = double.Parse(Console.ReadLine());

            if(vyska <= 0){
                Console.WriteLine("zkus to napsat znova");
                return;
            }

        Console.WriteLine("Zadej vahu (v kg):");
            double vaha = double.Parse(Console.ReadLine());

            if(vaha <= 0 || vaha > 635){
                Console.WriteLine("zkus to napsat znova");
                return;
            }
    
            double bmi = vaha / (vyska * vyska);
        Console.WriteLine("Tvoje BMI je: " + bmi);

        
        if(bmi < 18.5){

            Console.WriteLine("Podváha");
        }
        else if(bmi >= 18.5 && bmi < 25){

            Console.WriteLine("Normální váha");
        }
        else if(bmi >= 25 && bmi < 30){

            Console.WriteLine("Nadváha");
        }
        else if(bmi >= 30){

            Console.WriteLine("Obezita");

        }
        else{

            Console.WriteLine("napsal si špatnou váhu nebo výšku");
        }
    }
}