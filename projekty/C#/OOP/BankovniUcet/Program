class Program
{
    static void Main()
    {
        Console.Write("Vytvor heslo: ");
        string heslo = Console.ReadLine();

        BankovniUcet mujUcet = new BankovniUcet(5000, heslo);
        Console.WriteLine("Účet vytvořen se zůstatkem 5000 Kč.");

        mujUcet.Vlozit(1000);

        Console.Write("\nPro výběr peněz zadej heslo: ");
        string pokusHeslo = Console.ReadLine();
        mujUcet.Vybrat(2000, pokusHeslo);

        Console.Write("\nPro výpis historie zadej heslo: ");
        string hesloHistorie = Console.ReadLine();
        mujUcet.VypisHistorii(hesloHistorie);
    }
}